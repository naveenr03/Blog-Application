# Copy this file to ".env" in the repository root (never commit .env).
# Docker Compose loads it for the local Postgres service.

# Password for the postgres superuser in the compose "db" container.
# Default below matches application.properties so `mvn spring-boot:run` works without extra env.
POSTGRES_PASSWORD=postgres

# Optional: when running the API on the host against compose Postgres, override if you change the password above:
# SPRING_DATASOURCE_PASSWORD=postgres

# Optional: production-style overrides for local experiments (usually unset locally):
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/blog
# JWT_SECRET=
